import tkinter as tk
from tkinter import ttk, messagebox
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity

ITEMS = [
    {"title": "Python for Data Analysis", "tags": "python data analysis pandas visualization beginner"},
    {"title": "Machine Learning Basics", "tags": "python machine learning statistics scikit-learn beginner"},
    {"title": "Deep Learning with TensorFlow", "tags": "python deep learning tensorflow neural networks advanced"},
    {"title": "Frontend Web Development", "tags": "html css javascript ui design beginner"},
    {"title": "Backend Development with Django", "tags": "python django backend web development intermediate"},
    {"title": "Android App Development", "tags": "java kotlin android mobile development intermediate"},
    {"title": "Cloud Computing Essentials", "tags": "cloud aws devops deployment intermediate"},
    {"title": "Data Structures and Algorithms", "tags": "c++ algorithms problem solving data structures intermediate"},
    {"title": "Cyber Security Fundamentals", "tags": "security networking encryption risk analysis intermediate"},
    {"title": "UI/UX Design Basics", "tags": "ui ux design wireframe prototyping creativity beginner"},
]

CATEGORY_MAP = {
    "python": "python",
    "data": "data analysis",
    "analysis": "data analysis",
    "machine": "machine learning",
    "learning": "machine learning",
    "ai": "machine learning",
    "deep": "deep learning",
    "tensorflow": "deep learning",
    "web": "web development",
    "frontend": "web development",
    "backend": "backend development",
    "android": "android development",
    "mobile": "android development",
    "cloud": "cloud computing",
    "security": "cyber security",
    "cyber": "cyber security",
    "ui": "ui ux design",
    "ux": "ui ux design",
    "design": "ui ux design",
    "algorithm": "data structures and algorithms",
    "algorithms": "data structures and algorithms",
    "c++": "data structures and algorithms",
    "Food": "pasta , noodles , pizza ,  biryani , rice , curry , bread , sandwich , burger , steak , seafood , soup , salad , sushi , tacos , burrito , wrap , hot dog , sausage , kebab , gyro , spring roll , samosa , dumpling , ravioli , gnocchi , polenta , risotto , paella , fondue , charcuterie"
}

def build_model(items):
    corpus = [item["tags"] + " " + item["title"].lower() for item in items]
    vectorizer = TfidfVectorizer(ngram_range=(1, 2), stop_words="english")
    matrix = vectorizer.fit_transform(corpus)
    return vectorizer, matrix

VECTORizer, ITEM_MATRIX = build_model(ITEMS)

def enrich_user_text(text):
    words = text.lower().replace(",", " ").split()
    mapped = [CATEGORY_MAP.get(w, w) for w in words]
    return " ".join(mapped)

def recommend(user_input, top_n=5):
    enriched = enrich_user_text(user_input)
    user_vec = VECTORizer.transform([enriched])
    scores = cosine_similarity(user_vec, ITEM_MATRIX).flatten()
    ranked = sorted(enumerate(scores), key=lambda x: x[1], reverse=True)
    results = []
    for idx, score in ranked[:top_n]:
        item = ITEMS[idx]
        results.append((item["title"], float(score), item["tags"]))
    return results

def show_recommendations():
    user_input = entry.get().strip()
    if not user_input:
        messagebox.showwarning("Input Needed", "Please enter your interests or preferences.")
        return

    results = recommend(user_input, top_n=5)
    output_text.config(state="normal")
    output_text.delete("1.0", tk.END)

    if not results or results[0][1] == 0:
        output_text.insert(tk.END, "No strong match found. Try keywords like: python, machine learning, android, web, cloud, design.\n")
    else:
        for i, (title, score, tags) in enumerate(results, 1):
            output_text.insert(
                tk.END,
                f"{i}. {title}\n   Match Score: {score:.3f}\n   Tags: {tags}\n\n"
            )

    output_text.config(state="disabled")

def clear_all():
    entry.delete(0, tk.END)
    output_text.config(state="normal")
    output_text.delete("1.0", tk.END)
    output_text.config(state="disabled")

